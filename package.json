{
  "name": "gitea-mirror",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "USE_MOCK_DATA=true astro dev",
    "dev:real": "pnpm check-db && USE_MOCK_DATA=false astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "preview:mock": "USE_MOCK_DATA=true astro preview",
    "preview:real": "USE_MOCK_DATA=false astro preview",
    "start": "pnpm check-db && USE_MOCK_DATA=false node dist/server/entry.mjs",
    "start:mock": "USE_MOCK_DATA=true node dist/server/entry.mjs",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest",
    "create-dev-db": "tsx scripts/create-dev-db.ts",
    "init-db": "tsx scripts/init-db.ts",
    "check-db": "tsx scripts/check-db.ts",
    "cleanup-db": "rm -f gitea-mirror.db && rm -f gitea-mirror-dev.db",
    "setup:dev": "pnpm install && pnpm cleanup-db && pnpm create-dev-db",
    "setup:real": "pnpm install && pnpm cleanup-db && pnpm init-db"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.4",
    "@astrojs/node": "^9.2.0",
    "@astrojs/react": "^4.2.4",
    "@libsql/client": "^0.15.4",
    "@octokit/rest": "^21.1.1",
    "@radix-ui/react-dialog": "^1.1.7",
    "@radix-ui/react-select": "^2.1.7",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.4",
    "@tailwindcss/vite": "^4.1.3",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "astro": "^5.7.0",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "canvas-confetti": "^1.9.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.41.0",
    "fuse.js": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.488.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "superagent": "^10.2.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.3",
    "tw-animate-css": "^1.2.5",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/superagent": "^8.1.9",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.4.0",
    "better-sqlite3": "^9.6.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.19.3",
    "vitest": "^3.1.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "packageManager": "pnpm@10.8.1+sha512.c50088ba998c67b8ca8c99df8a5e02fd2ae2e2b29aaf238feaa9e124248d3f48f9fb6db2424949ff901cffbb5e0f0cc1ad6aedb602cd29450751d11c35023677"
}
