---
import { getCollection } from 'astro:content';
import MainLayout from '../../layouts/main.astro';

// Get all documentation entries, sorted by order
const docs = await getCollection('docs');
const sortedDocs = docs.sort((a, b) => {
  const orderA = a.data.order || 999;
  const orderB = b.data.order || 999;
  return orderA - orderB;
});
---

<MainLayout title="Documentation">
  <main class="max-w-5xl mx-auto px-4 py-12">
    <h1 class="text-3xl font-bold mb-2 text-center">Gitea Mirror Documentation</h1>
    <p class="mb-10 text-lg text-gray-400 text-center">Browse guides and technical docs for Gitea Mirror.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {sortedDocs.map(doc => (
        <a
          href={`/docs/${doc.slug}`}
          class="group block p-7 border border-gray-700 rounded-2xl bg-gray-900/60 hover:bg-blue-900/20 transition-colors shadow-lg focus:ring-2 focus:ring-blue-500 outline-none"
          tabindex="0"
        >
          <div class="flex items-center gap-3 mb-2">
            <span class="inline-block w-10 h-10 bg-blue-700/20 rounded-full flex items-center justify-center text-blue-400 text-2xl">
              {/* Optionally, add an icon here based on doc.slug or doc.data.title */}
              📄
            </span>
            <h2 class="text-xl font-semibold group-hover:text-blue-400 transition">{doc.data.title}</h2>
          </div>
          <p class="text-gray-300">{doc.data.description}</p>
        </a>
      ))}
    </div>
  </main>
</MainLayout>
