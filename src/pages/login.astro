---
import '../styles/global.css';
import { Button } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardFooter, CardHeader, CardTitle } from '@/components/ui/card';
import { GitMerge } from 'lucide-react';
import ThemeScript from '@/components/theme/ThemeScript.astro';

const generator = Astro.generator;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={generator} />
    <title>Login - Gitea Mirror</title>
    <ThemeScript />
  </head>
  <body>
    <div class="h-dvh flex items-center justify-center bg-muted/30 p-4">
      <Card className="w-full max-w-md">
        <CardHeader className="text-center">
          <div class="flex justify-center mb-4">
            <GitMerge className="h-10 w-10" />
          </div>
          <CardTitle className="text-2xl">Gitea Mirror</CardTitle>
          <CardDescription>
            Log in to manage your GitHub to Gitea mirroring
          </CardDescription>
        </CardHeader>
        <CardContent>
          <form id="login-form">
            <div class="space-y-4">
              <div>
                <label for="username" class="block text-sm font-medium mb-1">
                  Username
                </label>
                <input
                  id="username"
                  name="username"
                  type="text"
                  required
                  class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                  placeholder="Enter your username"
                />
              </div>
              <div>
                <label for="password" class="block text-sm font-medium mb-1">
                  Password
                </label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  required
                  class="w-full rounded-md border border-input bg-background px-3 py-2 text-sm shadow-sm transition-colors placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-1 focus-visible:ring-ring"
                  placeholder="Enter your password"
                />
              </div>
            </div>
          </form>
        </CardContent>
        <CardFooter>
          <Button type="submit" form="login-form" className="w-full">
            Log In
          </Button>
        </CardFooter>
        <div class="px-6 pb-6 text-center">
          <p class="text-sm text-muted-foreground">
            Don't have an account? Contact your administrator.
          </p>
        </div>
      </Card>
    </div>

    <script>
      async function handleLogin(e: SubmitEvent) {
        e.preventDefault();
        const form = e.target as HTMLFormElement;
        const formData = new FormData(form);
        const username = formData.get('username') as string | null;
        const password = formData.get('password') as string | null;
        
        if (!username || !password) {
          alert('Please enter both username and password');
          return;
        }
        
        // Prepare the data for the login API
        const loginData = { username, password };
        
        try {
          const response = await fetch('/api/auth?endpoint=login', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify(loginData),
            });
        
          const data = await response.json();
        
          if (response.ok) {
            alert('Login successful!');
            window.location.href = '/';
          } else {
            alert(data.error || 'Login failed. Please try again.');
          }
        } catch (error) {
          console.error('Error during login:', error);
          alert('An error occurred while logging in. Please try again.');
        }
      }
    
      // Attach the event listener to the form
      document.getElementById('login-form')?.addEventListener('submit', handleLogin);
    </script>
  </body>
</html>
