---
import '../styles/global.css';
import { MainLayout } from '@/components/layout/MainLayout';
import { ConfigTabs } from '@/components/config/ConfigTabs';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { ENV, MOCK_DATA } from '@/lib/config';
import { db, configs } from '@/lib/db';

// In production mode, fetch real data from the database
// In development mode, use mock data
let githubConfig = MOCK_DATA.githubConfig;
let giteaConfig = MOCK_DATA.giteaConfig;
let scheduleConfig = MOCK_DATA.scheduleConfig;

if (!ENV.USE_MOCK_DATA) {
  try {
    // Fetch configuration from database
    const dbConfigs = await db.select().from(configs).limit(1);
    if (dbConfigs.length > 0) {
      const config = dbConfigs[0];
      githubConfig = JSON.parse(config.githubConfig);
      giteaConfig = JSON.parse(config.giteaConfig);
      scheduleConfig = JSON.parse(config.scheduleConfig);
    }
  } catch (error) {
    console.error('Error fetching configuration:', error);
    // Fallback to mock data if database access fails
  }
}

// Client-side functions to handle form submissions
const handleSaveGitHubConfig = (values: any) => {
  console.log('Saving GitHub config:', values);
  // In a real implementation, this would call the API to save the config
};

const handleSaveGiteaConfig = (values: any) => {
  console.log('Saving Gitea config:', values);
  // In a real implementation, this would call the API to save the config
};

const handleSaveScheduleConfig = (values: any) => {
  console.log('Saving schedule config:', values);
  // In a real implementation, this would call the API to save the config
};
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Configuration - Gitea Mirror</title>
  </head>
  <body>
    <MainLayout>
      <div className="flex items-center justify-between mb-6">
        <h1 className="text-3xl font-bold">Configuration</h1>
      </div>

      <Card className="mb-6">
        <CardHeader>
          <CardTitle>Configuration Settings</CardTitle>
          <CardDescription>
            Configure your GitHub and Gitea connections, and set up automatic mirroring.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <ConfigTabs
            client:load
            githubConfig={githubConfig}
            giteaConfig={giteaConfig}
            scheduleConfig={scheduleConfig}
            onSaveGitHub={handleSaveGitHubConfig}
            onSaveGitea={handleSaveGiteaConfig}
            onSaveSchedule={handleSaveScheduleConfig}
          />
        </CardContent>
      </Card>

      <Card>
        <CardHeader>
          <CardTitle>Docker Configuration</CardTitle>
          <CardDescription>
            Equivalent Docker configuration for your current settings.
          </CardDescription>
        </CardHeader>
        <CardContent>
          <pre className="bg-muted p-4 rounded-md overflow-auto text-sm">
{`version: "3.3"
services:
  gitea-mirror:
    image: arunavo4/gitea-mirror:latest
    restart: unless-stopped
    container_name: gitea-mirror
    environment:
      - GITHUB_USERNAME=${mockGitHubConfig.username}
      - GITEA_URL=${mockGiteaConfig.url}
      - GITEA_TOKEN=your-gitea-token
      - GITHUB_TOKEN=your-github-token
      - MIRROR_ISSUES=${mockGitHubConfig.mirrorIssues}
      - MIRROR_STARRED=${mockGitHubConfig.mirrorStarred}
      - MIRROR_ORGANIZATIONS=${mockGitHubConfig.mirrorOrganizations}
      - PRESERVE_ORG_STRUCTURE=${mockGitHubConfig.preserveOrgStructure}
      - ONLY_MIRROR_ORGS=${mockGitHubConfig.onlyMirrorOrgs}
      - GITEA_ORGANIZATION=${mockGiteaConfig.organization}
      - GITEA_ORG_VISIBILITY=${mockGiteaConfig.visibility}
      - DELAY=${mockScheduleConfig.interval}`}
          </pre>
        </CardContent>
      </Card>
    </MainLayout>
  </body>
</html>
